@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="mx-12 mt-4 w-full space-y-8">
    <div class="space-y-4">
        <h1 class="text-[48px]">Energy Utility API</h1>
        <p class="text-xl">
            Use the Energy Utility API to calculate household energy expenditures by postcode. This API has two
            endpoints -
            one for fetching postcode level electricity meter data for over 1 million UK postcodes, and the second
            calculates the yearly consumption and cost of electricity based on postcode and household features passed as
            query string parameters.
        </p>
    </div>
    <div class="flex space-x-16 text-lg">
        <div class="space-y-4 flex-2">
            <div class="space-y-2">
                <h2>Examples:</h2>
                <input type="text" class="border border-2 border-[#BBBABA] rounded-lg w-full py-1 px-2"
                       disabled></input>
                <div class="bg-[#D9D9D9] h-[400px]">
                    <!-- vscode-format:off -->
                    <pre>
                        {
                        Postcode: 
                        MeanCons:
                        MedianCons:
                        }
                    </pre>
                    <!-- vscode-format:on -->
                </div>
            </div>
        </div>
        <div class="flex-3 space-y-4">
            <div class="flex justify-center">
                <label>
                    Search:
                    <input type="search" id="searchInput"
                           class="border border-2 border-[#BBBABA] rounded-lg py-1 px-2 w-[400px]"></input>
                </label>
            </div>
            <div class="overflow-auto h-[400px]">
                <table id="parameterTable" class="table-fixed w-full text-lg">
                    <thead class="bg-[#D9D9D9]">
                        <tr class="tableRow text-left m-4">
                            <th class="p-4 w-auto">Parameter</th>
                            <th class="p-4 w-auto">Required</th>
                            <th class="p-4 w-1/4">Value </th>
                            <th class="p-4 w-2/5">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.ParameterTableData.Rows)
                        {
                            <tr class="tableRow border-b-2 border-[#D9D9D9]">
                                <td class="p-4">@row.Parameter</td>
                                <td class="p-4">@row.Required</td>
                                <td class="p-4">
                                    <ol>
                                        @foreach (string key in @row.Value.Keys)
                                        {
                                            <li><strong>@key</strong> @row.Value[key]</li>
                                        }
                                    </ol>
                                </td>
                                <td class="p-4">
                                    @if (row.Parameter == "Postcode")
                                    {
                                        @row.Description[0].Description
                                    }
                                    else
                                    {
                                        <partial name="_SubtablePartial" model="row" />
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tableSearch.js" asp-append-version="true"></script>
}