@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="space-y-8">
    <div class="text-xl space-y-8 w-1/2 mx-auto mt-16">
        <h1 class="text-5xl pb-4 font-medium font-[Arial] border-b">@ViewData["Title"]</h1>
        <section>
            <form id="account" method="post" class="space-y-8">
                <h2>Use a local account to log in.</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="grid grid-cols-[1fr_2fr] grid-rows-2 gap-y-10">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <div>
                        <input asp-for="Input.Email"
                               class="border border-2 border-[#BBBABA] rounded-lg w-full py-1 px-2" autocomplete="username"
                               aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <div>
                        <input asp-for="Input.Password"
                               class="border border-2 border-[#BBBABA] rounded-lg w-full py-1 px-2"
                               autocomplete="current-password" aria-required="true" placeholder="password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <label asp-for="Input.RememberMe" class="form-label">
                        <div class="checkbox mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </div>
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit"
                            class="rounded-lg w-1/2 bg-[#2496FA] text-white text-2xl py-2 font-light">
                        Log in</button>
                    </div>
                    <div class="text-[#2496FA] text-base">
                        <p>
                            <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                        </p>
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                        </p>
                        <p>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                        </p>
                    </div>
                </form>
            </section>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
